{
	"name": "scrobble",
	"version": "1.0.0",
	"description": "A plugin for Obsidian (https://obsidian.md) to log songs with the Spotify API",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"type": "module",
	"keywords": [],
	"author": "yipqp",
	"license": "Apache-2.0",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"eslint": "^9.39.3",
		"eslint-plugin-obsidianmd": "^0.1.9",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "^5.9.3"
	}
}
